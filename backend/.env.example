# ── Supabase (Villages project) ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret   # Settings → API → JWT Settings

# ── OpenRouter (free-tier models) ────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   # Primary
OPENROUTER_MODEL_FALLBACK=google/gemma-4-31b-it:free # Fallback on 429

# ── CORS / Auth redirect (production) ────────────────────────
# Comma-separated allowed frontend origins. The first URL is used for
# magic-link redirects. e.g.:
#   FRONTEND_ORIGINS=https://villages-eight.vercel.app,https://villages.app
# (localhost + any *.vercel.app preview URL are already allowed automatically.)
FRONTEND_ORIGINS=
